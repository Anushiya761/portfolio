<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <title>Anushiyadevi | .NET Developer</title>
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="~/css/style.css?v=2" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/gh/devicons/devicon@latest/devicon.min.css">
</head>
<body>

    <nav class="navbar navbar-expand-lg navbar-dark bg-dark fixed-top shadow">
        <div class="container">
            <a class="navbar-brand fw-bold text-info" href="#">Anushiyadevi</a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navMenu">
                <span class="navbar-toggler-icon"></span>
            </button>

            <div class="collapse navbar-collapse" id="navMenu">
                <ul class="navbar-nav ms-auto">
                    <li class="nav-item me-3"><a class="nav-link" href="#about">About</a></li>
                    <li class="nav-item me-3"><a class="nav-link" href="#skills">Skills</a></li>
                    <li class="nav-item me-3"><a class="nav-link" href="#experience">Experience</a></li>
                    <li class="nav-item me-3"><a class="nav-link" href="#projects">Projects</a></li>
                    <li class="nav-item me-3"><a class="nav-link" href="#contact">Contact</a></li>
                    @* <li class="nav-item d-flex align-items-center ms-3">
                        <div class="theme-toggle">
                            <input type="checkbox" id="themeSwitch" />
                            <label for="themeSwitch" class="toggle-label">
                                <span class="toggle-ball"></span>
                            </label>
                        </div>
                    </li> *@
                </ul>
            </div>
        </div>
    </nav>

    <div class="social-sidebar">
        <a href="https://linkedin.com/in/anushiya2901" target="_blank" class="social-link linkedin">
            <i class="fab fa-linkedin-in"></i>
        </a>

        <a href="https://github.com/Anushiya761" target="_blank" class="social-link github">
            <i class="fab fa-github"></i>
        </a>
    @*<a href="https://mail.google.com/mail/?view=cm&fs=1&to=anushiya2901@gmail.com"
        target="_blank"
        class="social-link email">
        <i class="fas fa-envelope"></i>
     </a> *@
</div>

    <div>
        @RenderBody()
    </div>

    <div class="toast-container position-fixed top-0 end-0 p-3" style="z-index: 9999">

        @if (TempData["Success"] != null)
        {
            <div id="successToast" class="toast align-items-center text-bg-success border-0" role="alert">
                <div class="d-flex">
                    <div class="toast-body">
                        @TempData["Success"]
                    </div>
                    <button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast"></button>
                </div>
            </div>
        }

        @if (TempData["Error"] != null)
        {
            <div id="errorToast" class="toast align-items-center text-bg-danger border-0" role="alert">
                <div class="d-flex">
                    <div class="toast-body">
                        @TempData["Error"]
                    </div>
                    <button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast"></button>
                </div>
            </div>
        }

    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/typed.js@2.0.12"></script>
    <script>
        var typed = new Typed("#typing", {
            strings: ["ASP.NET Core Developer", "Kendo UI Developer", "Full Stack .NET Developer"],
            typeSpeed: 60,
            backSpeed: 40,
            loop: true
        });
    </script>
    <script src="https://unpkg.com/scrollreveal"></script>
    <script>
        ScrollReveal().reveal('.glass-card', {
            distance: '50px',
            duration: 800,
            easing: 'ease-in-out',
            origin: 'bottom',
            interval: 200
        });

        ScrollReveal().reveal('.timeline-item', {
            distance: '50px',
            duration: 800,  
            origin: 'left',
            interval: 200
        });
    </script>
    <script>
        window.addEventListener("load", function () {
            const skills = document.querySelectorAll(".skill-progress");

            skills.forEach(skill => {
                const width = skill.getAttribute("style").match(/\d+/)[0] + "%";
                skill.style.width = width;
            });
        });
    </script>

    <script src="https://cdn.jsdelivr.net/npm/typed.js@2.0.12"></script>

    <script>
        var typed = new Typed("#typing", {
            strings: [
                "ASP.NET Core Developer",
                "Full Stack .NET Developer",
                "Kendo UI Specialist",
                "Enterprise Application Developer"
            ],
            typeSpeed: 60,
            backSpeed: 40,
            backDelay: 1500,
            loop: true
        });
    </script>
    <script src="https://cdn.jsdelivr.net/npm/particles.js"></script>

    <script>
        particlesJS("particles-js", {
            particles: {
                number: { value: 60 },
                size: { value: 3 },
                color: { value: "#00c6ff" },
                line_linked: {
                    enable: true,
                    color: "#00c6ff",
                    opacity: 0.4
                },
                move: {
                    speed: 2
                }
            }
        });
    </script>

